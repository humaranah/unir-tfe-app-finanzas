<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:HA.TFG.AppFinanzas.App.Core.ViewModels;assembly=HA.TFG.AppFinanzas.Core"
             x:Class="HA.TFG.AppFinanzas.App.LoginPage"
             x:DataType="viewModels:WelcomeViewModel"
             Title="App Finanzas"
             Shell.NavBarIsVisible="False">

    <VerticalStackLayout Padding="40" Spacing="24" VerticalOptions="Center">

        <Label Text="App Finanzas"
               FontSize="32"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Label Text="Inicia sesión para continuar"
               FontSize="16"
               TextColor="Gray"
               HorizontalOptions="Center" />

        <Label Text="{Binding Error}"
               TextColor="OrangeRed"
               HorizontalOptions="Center"
               IsVisible="{Binding HasError}" />

        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" />

        <Button Text="Iniciar sesión con Auth0"
                Command="{Binding LoginCommand}"
                IsEnabled="{Binding IsNotBusy}"
                HorizontalOptions="Fill" />

    </VerticalStackLayout>

</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HA.TFG.AppFinanzas.Core.ViewModels;assembly=HA.TFG.AppFinanzas.Core"
             xmlns:model="clr-namespace:HA.TFG.AppFinanzas.Core.Movimientos;assembly=HA.TFG.AppFinanzas.Core"
             x:DataType="vm:MovimientosViewModel"
             x:Class="HA.TFG.AppFinanzas.App.Views.Pages.MovimientosPage"
             Title="Movimientos">

    <Shell.TitleView>
        <Grid HorizontalOptions="Fill">
            <Label Text="{Binding NombreCuenta}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
        </Grid>
    </Shell.TitleView>

    <Grid MaximumWidthRequest="800">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Button Text="{Binding MesAnterior}"
                Command="{Binding AnteriorCommand}"
                IsEnabled="{Binding IsAnteriorEnabled}"
                HorizontalOptions="Start"
                WidthRequest="100"
                Margin="24,0"/>
        <Label Text="{Binding Mes}"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
        <Button Text="{Binding MesSiguiente}"
                Command="{Binding SiguienteCommand}"
                IsEnabled="{Binding IsSiguienteEnabled}"
                HorizontalOptions="End"
                WidthRequest="100"
                Margin="24,0"/>
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Movimientos}"
                        IsGrouped="True"
                        IsVisible="{Binding HasMovimientos}"
                        Margin="20">
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="model:MovimientosPorFecha">
                    <Label Text="{Binding Fecha, StringFormat='{0:dd/MM/yyyy}'}"
                           FontAttributes="Bold"
                           BackgroundColor="LightGray"
                           Padding="10,5" />
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:MovimientoItem">
                    <Border Stroke="LightGray" Padding="10" Margin="0,0,0,10">
                        <StackLayout>
                            <Label Text="{Binding Concepto}" FontSize="16" FontAttributes="Bold" />
                            <Label Text="{Binding FechaMovimiento, StringFormat='Fecha: {0:dd/MM/yyyy}'}" FontSize="14" TextColor="Gray" />
                            <Label FontSize="14" TextColor="Green">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Monto: " />
                                        <Span Text="{Binding Importe, StringFormat='{0:N2}'}" />
                                        <Span Text=" " />
                                        <Span Text="{Binding Moneda}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </StackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding HasError}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="12">
            <Label Text="Algo salió mal"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="No pudimos obtener tus movimientos. Comprueba tu conexión e intenta de nuevo."
                   FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding SinMovimientos}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="12">
            <Label Text="Aún no hay movimientos"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="Agrega un movimiento para comenzar a registrar tus finanzas."
                   FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- FAB: nuevo movimiento -->
        <Button Grid.Row="1"
                Text="+"
                Command="{Binding NuevoMovimientoCommand}"
                AutomationProperties.Name="Nuevo movimiento"
                FontSize="24"
                FontAttributes="Bold"
                WidthRequest="56"
                HeightRequest="56"
                CornerRadius="28"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="24" />

    </Grid>
</ContentPage>
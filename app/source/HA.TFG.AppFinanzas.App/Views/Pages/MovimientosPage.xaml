<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HA.TFG.AppFinanzas.Core.ViewModels;assembly=HA.TFG.AppFinanzas.Core"
             xmlns:converters="clr-namespace:HA.TFG.AppFinanzas.App.Converters"
             xmlns:behaviors="clr-namespace:HA.TFG.AppFinanzas.App.Behaviors"
             xmlns:controls="clr-namespace:HA.TFG.AppFinanzas.App.Views.Controls"
             x:DataType="vm:MovimientosViewModel"
             x:Class="HA.TFG.AppFinanzas.App.Views.Pages.MovimientosPage"
             Title="Movimientos">
    <ContentPage.Resources>
        <converters:TipoMovimientoColorConverter x:Key="TipoMovimientoColor" />
        <converters:TipoMovimientoSignoConverter x:Key="TipoMovimientoSigno" />
        <converters:FilaParColorConverter x:Key="FilaParColor" />
    </ContentPage.Resources>

    <Shell.TitleView>
        <Grid HorizontalOptions="Fill">
            <Label Text="{Binding NombreCuenta}" Style="{StaticResource PageTitleLabel}" />
        </Grid>
    </Shell.TitleView>

    <Grid MaximumWidthRequest="800">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Button Text="{Binding MesAnterior}"
                Command="{Binding AnteriorCommand}"
                IsEnabled="{Binding IsAnteriorEnabled}"
                HorizontalOptions="Start"
                WidthRequest="100"
                Margin="24,0"/>
        <Label Text="{Binding Mes}"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
        <Button Text="{Binding MesSiguiente}"
                Command="{Binding SiguienteCommand}"
                IsEnabled="{Binding IsSiguienteEnabled}"
                HorizontalOptions="End"
                WidthRequest="100"
                Margin="24,0"/>
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Movimientos}"
                        IsGrouped="True"
                        IsVisible="{Binding HasMovimientos}">
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="vm:MovimientosPorFechaDisplay">
                    <Label Text="{Binding Fecha, StringFormat='{0:dd/MM/yyyy}'}"
                           FontAttributes="Bold"
                           Padding="20,8" />
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:MovimientoFilaItem">
                    <Grid ColumnDefinitions="*,auto,auto"
                          Padding="20,12"
                          BackgroundColor="{Binding IsEven, Converter={StaticResource FilaParColor}}">
                        <Grid.Behaviors>
                            <behaviors:HoverBackgroundBehavior />
                        </Grid.Behaviors>
                        <StackLayout Grid.Column="0">
                            <StackLayout.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MovimientosViewModel}}, Path=VerDetalleMovimientoCommand}"
                                    CommandParameter="{Binding Movimiento}" />
                            </StackLayout.GestureRecognizers>
                            <Label Text="{Binding Concepto}" FontSize="16" FontAttributes="Bold" />
                            <Label Text="{Binding FechaMovimiento, StringFormat='Fecha: {0:dd/MM/yyyy}'}" FontSize="14" TextColor="Gray" />
                            <Label FontSize="16"
                                   TextColor="{Binding TipoMovimiento, Converter={StaticResource TipoMovimientoColor}}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding TipoMovimiento, Converter={StaticResource TipoMovimientoSigno}}" />
                                        <Span Text="{Binding Importe, StringFormat='{0:N2}'}" />
                                        <Span Text=" " />
                                        <Span Text="{Binding Moneda}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </StackLayout>
                        <Button Grid.Column="1"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MovimientosViewModel}}, Path=EditarMovimientoCommand}"
                                CommandParameter="{Binding Movimiento}"
                                AutomationProperties.Name="Editar movimiento"
                                Style="{DynamicResource OutlinedButton}"
                                VerticalOptions="Center"
                                BorderWidth="1"
                                Padding="8,4">
                            <Button.ImageSource>
                                <FontImageSource FontFamily="FluentIcons"
                                                 Glyph="&#xE5B2;"
                                                 Size="24"
                                                 Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                            </Button.ImageSource>
                        </Button>
                        <Button Grid.Column="2"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MovimientosViewModel}}, Path=EliminarMovimientoCommand}"
                                CommandParameter="{Binding Movimiento}"
                                SemanticProperties.Description="Eliminar movimiento"
                                Style="{StaticResource DangerOutlinedButton}"
                                VerticalOptions="Center"
                                BorderWidth="1"
                                Margin="4,0,0,0"
                                Padding="8,4">
                            <Button.ImageSource>
                                <FontImageSource FontFamily="FluentIcons"
                                                 Glyph="&#xE47B;"
                                                 Size="24"
                                                 Color="{AppThemeBinding Light=#D32F2F, Dark=#FF6B6B}" />
                            </Button.ImageSource>
                        </Button>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <controls:EmptyStateView Grid.Row="1"
                                  IsVisible="{Binding HasError}"
                                  HorizontalOptions="Center"
                                  VerticalOptions="Center"
                                  Titulo="Algo salió mal"
                                  Descripcion="No pudimos obtener tus movimientos. Comprueba tu conexión e intenta de nuevo." />

        <controls:EmptyStateView Grid.Row="1"
                                  IsVisible="{Binding SinMovimientos}"
                                  HorizontalOptions="Center"
                                  VerticalOptions="Center"
                                  Titulo="Aún no hay movimientos"
                                  Descripcion="Agrega un movimiento para comenzar a registrar tus finanzas." />

        <!-- FAB: nuevo movimiento -->
        <Button Grid.Row="1"
                Text="+"
                Command="{Binding NuevoMovimientoCommand}"
                AutomationProperties.Name="Nuevo movimiento"
                FontSize="24"
                FontAttributes="Bold"
                WidthRequest="56"
                HeightRequest="56"
                CornerRadius="28"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="24" />

    </Grid>
</ContentPage>
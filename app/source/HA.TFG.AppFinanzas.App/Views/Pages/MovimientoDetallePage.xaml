<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HA.TFG.AppFinanzas.Core.Features.Movimientos;assembly=HA.TFG.AppFinanzas.Core"
             xmlns:controls="clr-namespace:HA.TFG.AppFinanzas.App.Views.Controls"
             x:DataType="vm:MovimientoDetalleViewModel"
             x:Class="HA.TFG.AppFinanzas.App.Views.Pages.MovimientoDetallePage"
             Title="Detalle del movimiento">

    <Shell.TitleView>
        <Grid HorizontalOptions="Fill">
            <Label Text="Detalle del movimiento" Style="{StaticResource PageTitleLabel}" />
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="40" Spacing="0" MaximumWidthRequest="600">

            <!-- Cargando -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               Margin="0,40,0,0" />

            <!-- Error -->
            <controls:EmptyStateView IsVisible="{Binding HasError}"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Margin="0,40,0,0"
                                     Titulo="Algo salió mal"
                                     Descripcion="No pudimos obtener el detalle del movimiento. Comprueba tu conexión e intenta de nuevo." />

            <!-- Detalle -->
            <VerticalStackLayout IsVisible="{Binding HasDetalle}" Spacing="0">

                <!-- Importe destacado -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,0,0,24">
                    <Label Text="{Binding ImporteFormateado}"
                           FontSize="36"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding Tipo}"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <BoxView Style="{StaticResource SectionSeparator}" Margin="0,0,0,20" />

                <controls:DetalleFilaView Etiqueta="Concepto"       Valor="{Binding Concepto}" />
                <controls:DetalleFilaView Etiqueta="Categoría"      Valor="{Binding NombreCategoria}" />
                <controls:DetalleFilaView Etiqueta="Fecha"          Valor="{Binding FechaFormateada}" />
                <controls:DetalleFilaView Etiqueta="Hora"           Valor="{Binding HoraFormateada}"
                                          IsVisible="{Binding MostrarHora}" />
                <controls:DetalleFilaView Etiqueta="Establecimiento" Valor="{Binding Establecimiento}"
                                          IsVisible="{Binding TieneEstablecimiento}" />
                <controls:DetalleFilaView Etiqueta="Nota"           Valor="{Binding Nota}"
                                          IsVisible="{Binding TieneNota}" />

                <!-- Comprobante (tiene control propio por el botón) -->
                <Grid ColumnDefinitions="140,*" Margin="0,0,0,16" ColumnSpacing="12"
                      IsVisible="{Binding TieneComprobante}">
                    <Label Grid.Column="0"
                           Text="Comprobante"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                        <Button Text="Ver comprobante"
                                Command="{Binding VerComprobanteCommand}"
                                IsEnabled="{Binding IsNotBusyComprobante}"
                                Style="{DynamicResource OutlinedButton}" />
                        <ActivityIndicator IsRunning="{Binding IsBusyComprobante}"
                                           IsVisible="{Binding IsBusyComprobante}"
                                           VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Grid>

                <BoxView Style="{StaticResource SectionSeparator}" Margin="0,8,0,24" />

                <!-- Editar -->
                <Button Text="Editar movimiento"
                        Command="{Binding EditarMovimientoCommand}"
                        HorizontalOptions="Fill" />

                <!-- Eliminar -->
                <Button Text="Eliminar movimiento"
                        Command="{Binding EliminarMovimientoCommand}"
                        HorizontalOptions="Fill"
                        Style="{StaticResource DangerOutlinedButton}"
                        Margin="0,8,0,0" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

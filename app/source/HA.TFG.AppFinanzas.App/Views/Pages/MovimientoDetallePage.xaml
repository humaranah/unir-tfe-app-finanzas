<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HA.TFG.AppFinanzas.Core.ViewModels;assembly=HA.TFG.AppFinanzas.Core"
             x:DataType="vm:MovimientoDetalleViewModel"
             x:Class="HA.TFG.AppFinanzas.App.Views.Pages.MovimientoDetallePage"
             Title="Detalle del movimiento">

    <Shell.TitleView>
        <Grid HorizontalOptions="Fill">
            <Label Text="Detalle del movimiento"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="40" Spacing="0" MaximumWidthRequest="600">

            <!-- Cargando -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               Margin="0,40,0,0" />

            <!-- Error -->
            <VerticalStackLayout IsVisible="{Binding HasError}"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="12"
                                 Margin="0,40,0,0">
                <Label Text="Algo salió mal"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="No pudimos obtener el detalle del movimiento. Comprueba tu conexión e intenta de nuevo."
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Detalle -->
            <VerticalStackLayout IsVisible="{Binding HasDetalle}" Spacing="0">

                <!-- Importe destacado -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,0,0,24">
                    <Label Text="{Binding ImporteFormateado}"
                           FontSize="36"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding Tipo}"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <BoxView HeightRequest="1"
                         Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                         Margin="0,0,0,20" />

                <!-- Concepto -->
                <Grid ColumnDefinitions="140,*" Margin="0,0,0,16" ColumnSpacing="12">
                    <Label Grid.Column="0"
                           Text="Concepto"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding Concepto}"
                           VerticalOptions="Center" />
                </Grid>

                <!-- Categoría -->
                <Grid ColumnDefinitions="140,*" Margin="0,0,0,16" ColumnSpacing="12">
                    <Label Grid.Column="0"
                           Text="Categoría"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding NombreCategoria}"
                           VerticalOptions="Center" />
                </Grid>

                <!-- Fecha -->
                <Grid ColumnDefinitions="140,*" Margin="0,0,0,16" ColumnSpacing="12">
                    <Label Grid.Column="0"
                           Text="Fecha"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding FechaFormateada}"
                           VerticalOptions="Center" />
                </Grid>

                <!-- Hora (opcional) -->
                <Grid ColumnDefinitions="140,*" Margin="0,0,0,16" ColumnSpacing="12"
                      IsVisible="{Binding MostrarHora}">
                    <Label Grid.Column="0"
                           Text="Hora"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding HoraFormateada}"
                           VerticalOptions="Center" />
                </Grid>

                <!-- Establecimiento (opcional) -->
                <Grid ColumnDefinitions="140,*" Margin="0,0,0,16" ColumnSpacing="12"
                      IsVisible="{Binding TieneEstablecimiento}">
                    <Label Grid.Column="0"
                           Text="Establecimiento"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding Establecimiento}"
                           VerticalOptions="Center" />
                </Grid>

                <!-- Nota (opcional) -->
                <Grid ColumnDefinitions="140,*" Margin="0,0,0,16" ColumnSpacing="12"
                      IsVisible="{Binding TieneNota}">
                    <Label Grid.Column="0"
                           Text="Nota"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding Nota}"
                           VerticalOptions="Center" />
                </Grid>

                <!-- Comprobante (si existe) -->
                <Grid ColumnDefinitions="140,*" Margin="0,0,0,16" ColumnSpacing="12"
                      IsVisible="{Binding TieneComprobante}">
                    <Label Grid.Column="0"
                           Text="Comprobante"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                        <Button Text="Ver comprobante"
                                ContentLayout="Left,8"
                                Command="{Binding VerComprobanteCommand}"
                                IsEnabled="{Binding IsNotBusyComprobante}"
                                Style="{DynamicResource OutlinedButton}">
                            <Button.ImageSource>
                                <FontImageSource FontFamily="FluentIcons"
                                                 Glyph="&#xF157;"
                                                 Size="18"
                                                 Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                            </Button.ImageSource>
                        </Button>
                        <ActivityIndicator IsRunning="{Binding IsBusyComprobante}"
                                           IsVisible="{Binding IsBusyComprobante}"
                                           VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Grid>

                <BoxView HeightRequest="1"
                         Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                         Margin="0,8,0,24" />

                <!-- Editar -->
                <Button Text="Editar movimiento"
                        Command="{Binding EditarMovimientoCommand}"
                        ContentLayout="Left,8"
                        HorizontalOptions="Fill">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="FluentIcons"
                                         Glyph="&#xE5B2;"
                                         Size="20"
                                         Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}" />
                    </Button.ImageSource>
                </Button>

                <!-- Eliminar -->
                <Button Text="Eliminar movimiento"
                        Command="{Binding EliminarMovimientoCommand}"
                        ContentLayout="Left,8"
                        HorizontalOptions="Fill"
                        Style="{DynamicResource OutlinedButton}"
                        Margin="0,8,0,0"
                        BorderWidth="1"
                        BorderColor="{AppThemeBinding Light=#D32F2F, Dark=#FF6B6B}"
                        TextColor="{AppThemeBinding Light=#D32F2F, Dark=#FF6B6B}">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="FluentIcons"
                                         Glyph="&#xE47B;"
                                         Size="20"
                                         Color="{AppThemeBinding Light=#D32F2F, Dark=#FF6B6B}" />
                    </Button.ImageSource>
                </Button>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

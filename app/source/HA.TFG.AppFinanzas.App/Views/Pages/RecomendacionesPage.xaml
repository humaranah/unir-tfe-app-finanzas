<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HA.TFG.AppFinanzas.Core.ViewModels;assembly=HA.TFG.AppFinanzas.Core"
             xmlns:markdown="clr-namespace:Indiko.Maui.Controls.Markdown;assembly=Indiko.Maui.Controls.Markdown"
             xmlns:controls="clr-namespace:HA.TFG.AppFinanzas.App.Views.Controls"
             x:DataType="vm:RecomendacionesViewModel"
             x:Class="HA.TFG.AppFinanzas.App.Views.Pages.RecomendacionesPage"
             Title="Recomendaciones">

    <Shell.TitleView>
        <Grid HorizontalOptions="Fill">
            <Label Text="Recomendaciones" Style="{StaticResource PageTitleLabel}" />
        </Grid>
    </Shell.TitleView>

    <Grid MaximumWidthRequest="800" RowSpacing="12" Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="12">

                <markdown:MarkdownView x:Name="markdownView"
                                       MarkdownText="{Binding Content}"
                                       UseAppTheme="True"
                                       IsVisible="{Binding HasContent}" />

                <controls:EmptyStateView IsVisible="{Binding HasError}"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Titulo="Algo salió mal"
                                         Descripcion="No pudimos obtener tus recomendaciones. Comprueba tu conexión e intenta de nuevo." />

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Entry Grid.Column="0"
                   Placeholder="Pregunta algo sobre tus finanzas..."
                   Text="{Binding Query}"
                   IsEnabled="{Binding IsNotBusy}"
                   ReturnCommand="{Binding PreguntarCommand}" />

            <Button Grid.Column="1"
                    Text="Enviar"
                    Command="{Binding PreguntarCommand}"
                    IsEnabled="{Binding IsNotBusy}" />
        </Grid>
    </Grid>

</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HA.TFG.AppFinanzas.App.Views.Controls.EmptyStateView"
             x:Name="this">
    <VerticalStackLayout HorizontalOptions="Center"
                         VerticalOptions="Center"
                         Spacing="12">
        <Label Text="{Binding Titulo, Source={x:Reference this}}"
               FontSize="18"
               FontAttributes="Bold"
               HorizontalOptions="Center" />
        <Label Text="{Binding Descripcion, Source={x:Reference this}}"
               FontSize="14"
               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center" />
    </VerticalStackLayout>
</ContentView>

<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HA.TFG.AppFinanzas.App.Views.Controls.DetalleFilaView"
             x:Name="this">
    <Grid ColumnDefinitions="140,*" Margin="0,0,0,16" ColumnSpacing="12">
        <Label Grid.Column="0"
               Text="{Binding Etiqueta, Source={x:Reference this}}"
               FontAttributes="Bold"
               VerticalOptions="Center" />
        <Label Grid.Column="1"
               Text="{Binding Valor, Source={x:Reference this}}"
               VerticalOptions="Center" />
    </Grid>
</ContentView>

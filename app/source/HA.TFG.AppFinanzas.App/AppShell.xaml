<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HA.TFG.AppFinanzas.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HA.TFG.AppFinanzas.App"
    Title="App Finanzas">

    <!-- Página inicial: solo visible mientras se comprueba la sesión -->
    <ShellContent
        Title=""
        ContentTemplate="{DataTemplate local:SplashLoadingPage}"
        Route="splash"
        Shell.NavBarIsVisible="False" />

    <ShellContent
        Title="Iniciar sesión"
        ContentTemplate="{DataTemplate local:LoginPage}"
        Route="login"
        Shell.NavBarIsVisible="False" />

    <ShellContent
        Title="Inicio"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="home" />

</Shell>
